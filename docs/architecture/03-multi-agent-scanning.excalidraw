      "seed": 746147320,
      "version": 1,
      "versionNonce": 552120824,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772701378025,
      "link": null,
      "locked": false,
      "syncedAt": "2026-03-05T09:16:04.024Z",
