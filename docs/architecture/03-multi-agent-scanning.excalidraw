    {
      "id": "d3-ann1-text",
      "type": "text",
      "x": 955,
      "y": 130,
      "width": 281.21759033203125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "mmd65ytaq2sv36a37ag"
      ],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 1429061256,
      "version": 1,
      "versionNonce": 1203903112,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772701378025,
      "link": null,
      "locked": false,
      "text": "Why 22 directories?\n\nProblem: In 2026, developers use 11\ndifferent AI agents. Each stores skills in\nits own folder — global and per-project.\n\nSolution: We maintain a list of all 11\nagents and scan both scopes for each.\nOne extension replaces checking 22\nfolders by hand.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why 22 directories?\n\nProblem: In 2026, developers use 11\ndifferent AI agents. Each stores skills in\nits own folder — global and per-project.\n\nSolution: We maintain a list of all 11\nagents and scan both scopes for each.\nOne extension replaces checking 22\nfolders by hand.",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-05T09:16:04.024Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-03-05T09:16:03.713Z"
    },
    {
      "id": "d3-ann2-bg",
      "type": "rectangle",
      "x": 940,
      "y": 325,
      "width": 340,
      "height": 195,
      "angle": 0,
      "strokeColor": "#e8590c",
      "backgroundColor": "#fff3bf",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
