    {
      "id": "d3-callout1-text",
      "type": "text",
      "x": 52,
      "y": 608,
      "strokeColor": "#495057",
      "text": "The Windows symlink gotcha:\nNode.js isDirectory() returns false\nfor symlinks. Must check\nisSymbolicLink() first, then\nfs.statSync() to follow.",
      "fontSize": 14,
      "fontFamily": 5,
      "createdAt": "2026-03-04T20:17:41.521Z",
      "updatedAt": "2026-03-04T20:17:41.521Z",
