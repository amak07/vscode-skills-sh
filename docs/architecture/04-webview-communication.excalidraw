    },
    {
      "id": "d4-web-detail",
      "type": "text",
      "x": 675,
      "y": 175,
      "strokeColor": "#868e96",
      "roughness": 0,
      "text": "Isolated iframe — no network,\nno filesystem, no Node.js\nCan only send/receive messages",
      "fontSize": 14,
      "fontFamily": 5,
      "createdAt": "2026-03-05T07:59:34.684Z",
      "updatedAt": "2026-03-05T08:00:07.502Z",
