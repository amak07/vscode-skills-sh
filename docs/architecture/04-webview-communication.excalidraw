    {
      "id": "d4-ann3-text",
      "type": "text",
      "x": 673.4820948350059,
      "y": 373.09305654391346,
      "width": 298.99761962890625,
      "height": 210,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "cBfH0EVJI1X72ma6txeyT"
      ],
      "frameId": null,
      "index": "b0C",
      "roundness": null,
      "seed": 1464340616,
      "version": 1,
      "versionNonce": 2040549112,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772702387409,
      "link": null,
      "locked": false,
      "text": "The stale response trick\n\nUser clicks skill A, then quickly clicks B.\nBoth API requests are in-flight at once.\n\nA counter increments on each request.\nBefore sending any response, the handler\nchecks: \"Am I still the latest request?\"\nIf not, the old response is silently dropped.\n\nOne number prevents the wrong skill's\ndata from showing up.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The stale response trick\n\nUser clicks skill A, then quickly clicks B.\nBoth API requests are in-flight at once.\n\nA counter increments on each request.\nBefore sending any response, the handler\nchecks: \"Am I still the latest request?\"\nIf not, the old response is silently dropped.\n\nOne number prevents the wrong skill's\ndata from showing up.",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-05T09:20:07.452Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-03-05T09:20:07.142Z"
    }
  ],
