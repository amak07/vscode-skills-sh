    },
    {
      "id": "d4-ann2-text",
      "type": "text",
      "x": 350,
      "y": 330,
      "width": 268.95367431640625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0A",
      "roundness": null,
      "seed": 1155629448,
      "version": 1,
      "versionNonce": 774704888,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772702250117,
      "link": null,
      "locked": false,
      "text": "Why can't the webview fetch data?\n\nProblem: The webview runs in a locked-\ndown browser sandbox. Its security\npolicy blocks ALL network requests.\n\nSolution: The webview sends a message\nto the extension, the extension makes\nthe API call, and sends the data back.\nAll data is proxied through the host.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why can't the webview fetch data?\n\nProblem: The webview runs in a locked-\ndown browser sandbox. Its security\npolicy blocks ALL network requests.\n\nSolution: The webview sends a message\nto the extension, the extension makes\nthe API call, and sends the data back.\nAll data is proxied through the host.",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-05T09:20:07.452Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-03-05T09:20:07.142Z"
    },
    {
      "id": "d4-ann3-bg",
      "type": "rectangle",
      "x": 656.152740427227,
      "y": 360.76370213613427,
      "width": 326.29541094525706,
      "height": 233.99314839136366,
      "angle": 0,
      "strokeColor": "#e8590c",
      "backgroundColor": "#fff3bf",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
