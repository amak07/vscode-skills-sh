      "roundness": {
        "type": 3
      },
      "seed": 1482766840,
      "version": 1,
      "versionNonce": 176188808,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772702250117,
      "link": null,
      "locked": false,
      "syncedAt": "2026-03-05T09:20:07.452Z",
