      "frameId": null,
      "text": "Why three? Windows FileSystemWatcher doesn't reliably\ndetect changes through symlinks. Shell integration requires\nVS Code 1.93+. Timeout catches all remaining edge cases.",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why three? Windows FileSystemWatcher doesn't reliably\ndetect changes through symlinks. Shell integration requires\nVS Code 1.93+. Timeout catches all remaining edge cases.",
      "autoResize": true,
      "lineHeight": 1.25
    },
